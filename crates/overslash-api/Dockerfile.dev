# Stage 1: generate a dependency recipe
FROM rust:1.94-slim-trixie AS chef
# Cache toolchain layer: only re-downloaded when rust-toolchain.toml changes
COPY rust-toolchain.toml /app/
RUN rustup show
RUN cargo install cargo-chef --locked
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY crates/overslash-core/Cargo.toml crates/overslash-core/Cargo.toml
COPY crates/overslash-db/Cargo.toml crates/overslash-db/Cargo.toml
COPY crates/overslash-api/Cargo.toml crates/overslash-api/Cargo.toml
COPY tests/mock-target/Cargo.toml tests/mock-target/Cargo.toml
COPY crates/overslash-db/migrations crates/overslash-db/migrations
COPY .sqlx .sqlx
COPY services services
# Stub sources so cargo-chef can resolve the workspace
RUN mkdir -p crates/overslash-core/src crates/overslash-db/src crates/overslash-api/src tests/mock-target/src && \
    echo "fn main() {}" > crates/overslash-api/src/main.rs && \
    echo "fn main() {}" > tests/mock-target/src/main.rs && \
    touch crates/overslash-core/src/lib.rs crates/overslash-db/src/lib.rs
RUN cargo chef prepare --recipe-path recipe.json

# Stage 2: build dependencies (cached image layer)
FROM rust:1.94-slim-trixie AS deps
COPY rust-toolchain.toml /app/
RUN rustup show
RUN apt-get update && apt-get install -y pkg-config libssl-dev clang mold && rm -rf /var/lib/apt/lists/*
RUN cargo install cargo-chef --locked
WORKDIR /app

COPY --from=chef /app/recipe.json recipe.json
COPY crates/overslash-db/migrations crates/overslash-db/migrations
COPY .sqlx .sqlx
COPY services services

ENV SQLX_OFFLINE=true
ENV CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=clang
ENV CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUSTFLAGS="-C link-arg=-fuse-ld=mold"

RUN cargo chef cook --recipe-path recipe.json

# Stage 3: dev runtime — deps already in /app/target from the image layer
FROM rust:1.94-slim-trixie

WORKDIR /app

# Cache toolchain layer: only re-downloaded when rust-toolchain.toml changes
COPY rust-toolchain.toml ./
RUN rustup show

RUN apt-get update && apt-get install -y pkg-config libssl-dev clang mold && rm -rf /var/lib/apt/lists/*
RUN cargo install cargo-watch --locked

# Copy workspace manifests
COPY Cargo.toml Cargo.lock ./
COPY crates/overslash-core/Cargo.toml crates/overslash-core/Cargo.toml
COPY crates/overslash-db/Cargo.toml crates/overslash-db/Cargo.toml
COPY crates/overslash-api/Cargo.toml crates/overslash-api/Cargo.toml
COPY tests/mock-target/Cargo.toml tests/mock-target/Cargo.toml

# Copy migrations, sqlx cache, services
COPY crates/overslash-db/migrations crates/overslash-db/migrations
COPY .sqlx .sqlx
COPY services services

# Pre-built dependencies live in the image — no volume needed
COPY --from=deps /app/target target
COPY --from=deps /usr/local/cargo/registry /usr/local/cargo/registry

ENV CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=clang
ENV CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUSTFLAGS="-C link-arg=-fuse-ld=mold"

# Source dirs are mounted as volumes at runtime; clear our crate fingerprints so cargo rebuilds them
CMD ["sh", "-c", "rm -rf target/debug/.fingerprint/overslash* target/debug/.fingerprint/mock-target* 2>/dev/null; cargo watch -x 'run -p overslash-api'"]
