{
  "rewrites": [
    { "source": "/v1/:path*",             "has": [{ "type": "host", "value": "app.overslash.com" }], "destination": "https://api.overslash.com/v1/:path*" },
    { "source": "/auth/:path*",           "has": [{ "type": "host", "value": "app.overslash.com" }], "destination": "https://api.overslash.com/auth/:path*" },
    { "source": "/health",                "has": [{ "type": "host", "value": "app.overslash.com" }], "destination": "https://api.overslash.com/health" },
    { "source": "/SKILL.md",              "has": [{ "type": "host", "value": "app.overslash.com" }], "destination": "https://api.overslash.com/SKILL.md" },
    { "source": "/public/secrets/:path*", "has": [{ "type": "host", "value": "app.overslash.com" }], "destination": "https://api.overslash.com/public/secrets/:path*" },

    { "source": "/v1/:path*",             "destination": "https://api.dev.overslash.com/v1/:path*" },
    { "source": "/auth/:path*",           "destination": "https://api.dev.overslash.com/auth/:path*" },
    { "source": "/health",                "destination": "https://api.dev.overslash.com/health" },
    { "source": "/SKILL.md",              "destination": "https://api.dev.overslash.com/SKILL.md" },
    { "source": "/public/secrets/:path*", "destination": "https://api.dev.overslash.com/public/secrets/:path*" }
  ]
}
