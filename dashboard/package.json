{
  "name": "overslash-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:static": "ADAPTER=static vite build",
    "build:strict": "SVELTE_STRICT=true vite build && node scripts/check-chunk-sizes.mjs",
    "build:strict:static": "SVELTE_STRICT=true ADAPTER=static vite build && node scripts/check-chunk-sizes.mjs",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.59.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/roboto-mono": "^5.2.8",
    "codemirror": "^6.0.2",
    "yaml": "^2.8.3"
  }
}
