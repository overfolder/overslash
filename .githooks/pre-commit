#!/bin/bash
set -e

echo "Running pre-commit checks..."

echo "  cargo fmt --check"
cargo fmt --check || {
    echo "ERROR: Code not formatted. Run 'cargo fmt' first."
    exit 1
}

echo "  cargo clippy"
cargo clippy --workspace -- -D warnings || {
    echo "ERROR: Clippy warnings found. Fix them before committing."
    exit 1
}

# Check SCHEMA.sql is up to date (only if DB is reachable)
if git diff --cached --name-only | grep -qE 'migrations/'; then
    if pg_isready -h localhost -p 5432 -U overslash -q 2>/dev/null; then
        echo "  schema check (migrations changed)"
        TMPSCHEMA=$(mktemp)
        pg_dump --schema-only --no-owner --no-acl --schema=public \
            --exclude-table=_sqlx_migrations \
            "${DATABASE_URL:-postgres://overslash:overslash@localhost:5432/overslash}" \
            > "$TMPSCHEMA" 2>/dev/null
        if ! diff -q SCHEMA.sql "$TMPSCHEMA" >/dev/null 2>&1; then
            echo "ERROR: SCHEMA.sql is out of date. Run 'make schema' and stage it."
            rm -f "$TMPSCHEMA"
            exit 1
        fi
        rm -f "$TMPSCHEMA"
    else
        echo "  schema check skipped (DB not reachable)"
    fi
fi

echo "Pre-commit checks passed."
