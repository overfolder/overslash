#!/bin/bash
set -e

echo "Running pre-commit checks..."

# Resolve DATABASE_URL (from env or .env file) with fallback to dev port 55432
DB_URL="${DATABASE_URL:-}"
if [ -z "$DB_URL" ] && [ -f .env ]; then
    DB_URL=$(grep -m1 '^DATABASE_URL=' .env | cut -d= -f2-)
fi
DB_URL="${DB_URL:-postgres://overslash:overslash@localhost:55432/overslash}"

# Extract host and port from DATABASE_URL
DB_HOST=$(echo "$DB_URL" | sed -n 's|.*@\([^:/]*\).*|\1|p')
DB_PORT=$(echo "$DB_URL" | sed -n 's|.*:\([0-9]*\)/.*|\1|p')
DB_HOST="${DB_HOST:-localhost}"
DB_PORT="${DB_PORT:-55432}"

DB_REACHABLE=false
if pg_isready -h "$DB_HOST" -p "$DB_PORT" -U overslash -q 2>/dev/null; then
    DB_REACHABLE=true
fi

# Use sqlx offline cache when the database is not reachable
if [ -z "$SQLX_OFFLINE" ] && [ "$DB_REACHABLE" = "false" ]; then
    echo "  DB not reachable, using SQLX_OFFLINE=true"
    export SQLX_OFFLINE=true
fi

# Guard against silently-discarded auth extractors in route handlers.
# Pattern: `_auth: AuthContext` / `_org_id` / `_identity_id` in argument
# position means the handler accepted an authenticated context and then
# threw it away — usually a multi-tenancy bug (see PR #60 sentry review).
# If a handler genuinely doesn't need auth it should not extract it at
# all; this gate is intentionally strict.
echo "  ignored-auth scan"
IGNORED_AUTH_HITS=$(git ls-files 'crates/*/src/routes/*.rs' 2>/dev/null \
    | xargs -r grep -nE '\b_(auth|org_id|identity_id)\b\s*:\s*(AuthContext|Uuid|MaybeAuthContext)' \
    || true)
if [ -n "$IGNORED_AUTH_HITS" ]; then
    echo "ERROR: route handlers must not silently discard auth extractors:" >&2
    echo "$IGNORED_AUTH_HITS" >&2
    echo "Either use the value (e.g. enforce org_id on the query) or remove" >&2
    echo "the extractor entirely. See PR #60 for context." >&2
    exit 1
fi

echo "  cargo fmt --check"
cargo fmt --check || {
    echo "ERROR: Code not formatted. Run 'cargo fmt' first."
    exit 1
}

echo "  cargo clippy"
cargo clippy --workspace -- -D warnings || {
    echo "ERROR: Clippy warnings found. Fix them before committing."
    exit 1
}

# Check sqlx offline cache is up to date (requires live DB)
if [ "$SQLX_OFFLINE" = "true" ]; then
    echo "  sqlx prepare --check skipped (DB not reachable)"
else
    echo "  cargo sqlx prepare --check"
    cargo sqlx prepare --workspace --check || {
        echo "ERROR: sqlx offline cache is stale. Run 'make sqlx-prepare' and stage .sqlx/."
        exit 1
    }
fi

# Check SCHEMA.sql is up to date (only if DB is reachable and migrations changed)
if git diff --cached --name-only | grep -qE 'migrations/'; then
    if [ "$DB_REACHABLE" = "true" ]; then
        echo "  schema check (migrations changed)"
        TMPSCHEMA=$(mktemp)
        pg_dump --schema-only --no-owner --no-acl --schema=public \
            --exclude-table=_sqlx_migrations \
            "$DB_URL" \
            | grep -v '^\\restrict\|^\\unrestrict' > "$TMPSCHEMA" 2>/dev/null
        COMMITTED_SCHEMA=$(mktemp)
        grep -v '^\\restrict\|^\\unrestrict' SCHEMA.sql > "$COMMITTED_SCHEMA"
        if ! diff -q "$COMMITTED_SCHEMA" "$TMPSCHEMA" >/dev/null 2>&1; then
            echo "ERROR: SCHEMA.sql is out of date. Run 'make schema' and stage it."
            rm -f "$TMPSCHEMA" "$COMMITTED_SCHEMA"
            exit 1
        fi
        rm -f "$TMPSCHEMA" "$COMMITTED_SCHEMA"
    else
        echo "  schema check skipped (DB not reachable on $DB_HOST:$DB_PORT)"
    fi
fi

# Dashboard checks (only if dashboard/ files are staged)
if git diff --cached --name-only --diff-filter=ACMR | grep -q '^dashboard/'; then
    echo "  dashboard/ changes detected, running svelte-check"
    if [ ! -d dashboard/node_modules ]; then
        echo "ERROR: dashboard/node_modules missing. Run 'cd dashboard && npm install' first."
        exit 1
    fi
    (cd dashboard && npm run check) || {
        echo "ERROR: dashboard svelte-check failed."
        exit 1
    }
fi

echo "Pre-commit checks passed."
