  "query": "SELECT id, org_id, identity_id, group_id, scope, max_requests, window_seconds, created_at, updated_at\n         FROM rate_limits\n         WHERE org_id = $1 AND scope = 'group' AND group_id = ANY($2)\n         ORDER BY (max_requests::float8 / NULLIF(window_seconds, 0)) DESC NULLS LAST\n         LIMIT 1",
