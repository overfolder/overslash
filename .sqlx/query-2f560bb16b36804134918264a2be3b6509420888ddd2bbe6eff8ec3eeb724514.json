{
  "db_name": "PostgreSQL",
  "query": "SELECT g.id, g.org_id, g.name, g.description, g.allow_raw_http, g.is_system, g.system_kind, g.owner_identity_id, g.created_at, g.updated_at\n         FROM groups g\n         JOIN identity_groups ig ON ig.group_id = g.id\n         JOIN identities i ON i.id = ig.identity_id\n         WHERE ig.identity_id = $1 AND g.org_id = $2 AND i.org_id = $2\n         ORDER BY g.name",
