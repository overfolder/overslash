  "query": "INSERT INTO secrets (org_id, name) VALUES ($1, $2)\n         ON CONFLICT (org_id, name) DO UPDATE SET\n           current_version = secrets.current_version + 1,\n           updated_at = now(),\n           deleted_at = NULL\n         RETURNING id, org_id, name, current_version, deleted_at, created_at, updated_at",
