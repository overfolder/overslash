  "query": "SELECT g.id, g.org_id, g.name, g.description, g.allow_raw_http, g.created_at, g.updated_at\n         FROM groups g\n         JOIN identity_groups ig ON ig.group_id = g.id\n         WHERE ig.identity_id = $1\n         ORDER BY g.name",
